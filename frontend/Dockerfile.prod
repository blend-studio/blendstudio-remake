FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:20-alpine
WORKDIR /app
RUN npm install -g serve
# Place dist at public root for serving at '/'
RUN mkdir -p public
COPY --from=build /app/dist/ ./public/
EXPOSE 5173
CMD ["serve", "-s", "public", "-l", "5173"]
