FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:20-alpine
WORKDIR /app
RUN npm install -g serve
# Nest dist under the base path so serve can find the files
RUN mkdir -p public/blendstudio-remake
COPY --from=build /app/dist/ ./public/blendstudio-remake/
EXPOSE 5173
CMD ["serve", "-s", "public", "-l", "5173"]
